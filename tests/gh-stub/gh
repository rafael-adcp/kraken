#!/usr/bin/env bash
# Programmable `gh` stub for the kraken conformance suite (tests/run-tests.sh
# puts this directory first on PATH). It models just enough of GitHub for the
# bundled transition scripts: issue state, labels, and — the part that matters —
# server-side comment ordering. The scripts' own --jq expressions are evaluated
# by the real `jq`, so the filters under test are the shipped ones, never a
# reimplementation.
#
# State layout (under $GH_STUB_STATE):
#   issues/<n>/title       one line
#   issues/<n>/createdAt   ISO timestamp
#   issues/<n>/state       "open" | "closed"
#   issues/<n>/labels      one label per line
#   issues/<n>/body        issue body text (optional; absent = empty body)
#   issues/<n>/blocked_by  one blocker issue number per line (optional;
#                          absent = no native blockers, i.e. the real API's [])
#   issues/<n>/comments/NNNN.md   bodies, NNNN = server order
#   log                    every invocation, one per line
#
# Knobs:
#   GH_STUB_FAIL=<ERE>    any invocation whose args match exits 1 (network sim)
#   GH_STUB_BARRIER=<n>   `issue view --json labels` blocks until n callers
#                         arrive — holds every racer inside the claim window so
#                         the race test is deterministic, not timing-dependent
#
# `gh api repos/OWNER/REPO/issues/N/dependencies/blocked_by` models GitHub's
# native blocked-by relationships: emits a JSON array of {number, state},
# state read from each blocker's own issues/<n>/state file, so closing a
# blocker in the stub is exactly `echo closed > issues/<n>/state`.
set -u

STATE="${GH_STUB_STATE:?gh stub: GH_STUB_STATE not set}"
printf 'gh %s\n' "$*" >> "$STATE/log"

if [ -n "${GH_STUB_FAIL:-}" ] && printf '%s' "$*" | grep -Eq "$GH_STUB_FAIL"; then
  echo "gh-stub: injected failure for: $*" >&2
  exit 1
fi

# mkdir is the only portable atomic primitive (Git Bash has no flock) — it
# serializes writes, which is exactly GitHub's server-side ordering.
lock() {
  local i=0
  until mkdir "$STATE/.lock" 2>/dev/null; do
    sleep 0.05
    i=$((i + 1))
    [ "$i" -gt 200 ] && { echo "gh-stub: lock timeout" >&2; exit 99; }
  done
}
unlock() { rmdir "$STATE/.lock"; }

# --- argument parsing (only the shapes the transition scripts use) -----------
# `pr` is here only for the agent-behavior harness (tests/agent): the unleash
# skill opens the delivery PR with `gh pr create`, which no transition script
# calls, so the conformance suite never reaches this branch. We record the PR
# as an artifact (pr/NNNN.json) instead of talking to GitHub, and capture -R's
# repo (the conformance paths ignore it) so a PR is attributable to a repo.
sub="" issue="" jsonf="" jqexpr="" add_label="" remove_label="" body="" endpoint="" limit=""
repo="" pr_sub="" title="" head="" base="" draft=0
label_filters=()
while [ $# -gt 0 ]; do
  case "$1" in
    -R)             repo="$2"; shift 2 ;;
    issue)          sub="$2"; shift 2 ;;
    pr)             sub="pr"; pr_sub="$2"; shift 2 ;;
    api)            sub="api"; endpoint="$2"; shift 2 ;;
    --json)         jsonf="$2"; shift 2 ;;
    --jq)           jqexpr="$2"; shift 2 ;;
    --label)        label_filters+=("$2"); shift 2 ;;
    --add-label)    add_label="$2"; shift 2 ;;
    --remove-label) remove_label="$2"; shift 2 ;;
    --title)        title="$2"; shift 2 ;;
    --head)         head="$2"; shift 2 ;;
    --base)         base="$2"; shift 2 ;;
    --draft)        draft=1; shift ;;
    --body)         body="$2"; shift 2 ;;
    --body-file)    body="$(cat "$2")"; shift 2 ;;
    --limit)        limit="$2"; shift 2 ;;
    --state)        shift 2 ;;
    -*)             shift ;;
    *)              issue="$1"; shift ;;
  esac
done

issue_json() { # $1 = issue dir; emit {number,title,createdAt,labels:[{name}]}
  # One jq per issue (not four): the list case builds a whole queue, so a
  # tighter fork budget here is what keeps large-queue cases (tests/t/14)
  # from dominating the suite. Files are read straight into jq via --rawfile.
  local d="$1"
  jq -n \
    --arg n "$(basename "$d")" \
    --rawfile title "$d/title" \
    --rawfile created "$d/createdAt" \
    --rawfile labels "$d/labels" \
    '{
       number: ($n | tonumber),
       title: ($title | rtrimstr("\n")),
       createdAt: ($created | rtrimstr("\n")),
       labels: ($labels | rtrimstr("\n") | split("\n") | map(select(. != "") | {name: .}))
     }'
}

emit() { # $1 = JSON; apply --jq like gh does (raw strings, like jq -r)
  if [ -n "$jqexpr" ]; then
    printf '%s' "$1" | jq -r "$jqexpr"
  else
    printf '%s\n' "$1"
  fi
}

case "$sub" in
  list)
    items=""
    for d in "$STATE"/issues/*/; do
      [ -d "$d" ] || continue
      [ "$(cat "$d/state")" = "open" ] || continue
      ok=1
      for lf in ${label_filters[@]+"${label_filters[@]}"}; do
        grep -qxF -- "$lf" "$d/labels" || { ok=0; break; }
      done
      [ "$ok" -eq 1 ] || continue
      items="${items}$(issue_json "$d")"
    done
    # Honor --limit like real gh: it page-fetches newest-first (created desc)
    # and stops at the ceiling, so an over-limit queue silently loses its
    # OLDEST tasks. Modeling that truncation is what gives the pagination
    # conformance case (tests/t/14) its teeth; absent --limit means no cap.
    all="$(printf '%s' "$items" | jq -s 'sort_by(.createdAt) | reverse')"
    if [ -n "$limit" ]; then
      all="$(printf '%s' "$all" | jq --argjson lim "$limit" '.[:$lim]')"
    fi
    emit "$all"
    ;;

  view)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    if [ "$jsonf" = "labels" ] && [ -n "${GH_STUB_BARRIER:-}" ]; then
      mkdir -p "$STATE/.barrier"
      : > "$STATE/.barrier/$$"
      i=0
      while [ "$(ls "$STATE/.barrier" | wc -l)" -lt "$GH_STUB_BARRIER" ]; do
        sleep 0.05
        i=$((i + 1))
        [ "$i" -gt 100 ] && break # a stuck partner must not hang the suite
      done
    fi
    case "$jsonf" in
      labels)
        emit "$(jq -n --argjson labels "$(jq -R '{name: .}' < "$d/labels" | jq -s .)" '{labels: $labels}')"
        ;;
      body)
        emit "$(jq -n --arg body "$([ -f "$d/body" ] && cat "$d/body" || true)" '{body: $body}')"
        ;;
      state)
        st="$(cat "$d/state" | tr '[:lower:]' '[:upper:]')"
        emit "$(jq -n --arg state "$st" '{state: $state}')"
        ;;
      comments)
        bodies=""
        for f in "$d"/comments/*.md; do
          [ -f "$f" ] || continue
          bodies="${bodies}$(jq -Rs '{body: .}' < "$f")"
        done
        emit "$(jq -n --argjson c "$(printf '%s' "$bodies" | jq -s .)" '{comments: $c}')"
        ;;
      *)
        echo "gh-stub: unsupported --json '$jsonf' for issue view" >&2; exit 1
        ;;
    esac
    ;;

  edit)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    lock
    if [ -n "$add_label" ]; then
      grep -qxF -- "$add_label" "$d/labels" || printf '%s\n' "$add_label" >> "$d/labels"
    fi
    if [ -n "$remove_label" ]; then
      grep -vxF -- "$remove_label" "$d/labels" > "$d/labels.tmp" || true
      mv "$d/labels.tmp" "$d/labels"
    fi
    unlock
    ;;

  comment)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    lock
    n=$(( $(ls "$d/comments" | wc -l) + 1 ))
    printf '%s\n' "$body" > "$d/comments/.tmp.$$"
    mv "$d/comments/.tmp.$$" "$d/comments/$(printf '%04d' "$n").md"
    unlock
    ;;

  api)
    # Only the shape list-startable.sh needs:
    #   repos/OWNER/REPO/issues/N/dependencies/blocked_by -> [{number,state}]
    case "$endpoint" in
      */issues/*/dependencies/blocked_by)
        n="$(printf '%s' "$endpoint" | sed -n 's#.*/issues/\([0-9][0-9]*\)/dependencies/blocked_by#\1#p')"
        d="$STATE/issues/$n"
        [ -d "$d" ] || { echo "gh-stub: no such issue $n" >&2; exit 1; }
        items=""
        if [ -f "$d/blocked_by" ]; then
          while IFS= read -r bn; do
            [ -n "$bn" ] || continue
            bstate="closed"
            [ -f "$STATE/issues/$bn/state" ] && bstate="$(cat "$STATE/issues/$bn/state")"
            items="${items}$(jq -n --argjson num "$bn" --arg state "$bstate" '{number: $num, state: $state}')"
          done < "$d/blocked_by"
        fi
        emit "$(printf '%s' "$items" | jq -s .)"
        ;;
      *)
        echo "gh-stub: unsupported api endpoint '$endpoint'" >&2; exit 1
        ;;
    esac
    ;;

  pr)
    # Only `pr create` — the delivery PR the unleash skill opens on the work
    # repo. Record it as an artifact (never a real GitHub call) and print a
    # plausible URL on stdout, exactly what real `gh pr create` emits, so the
    # skill can quote it back in the result comment / pr: machine line.
    case "$pr_sub" in
      create)
        lock
        mkdir -p "$STATE/pr"
        n=$(( $(ls "$STATE/pr" 2>/dev/null | wc -l) + 1 ))
        url="https://github.com/${repo:-owner/repo}/pull/${n}"
        jq -n \
          --arg repo "$repo" --arg title "$title" --arg body "$body" \
          --arg head "$head" --arg base "$base" \
          --argjson draft "$draft" --arg url "$url" \
          '{repo:$repo, title:$title, body:$body, head:$head, base:$base, draft:($draft==1), url:$url}' \
          > "$STATE/pr/$(printf '%04d' "$n").json"
        unlock
        printf '%s\n' "$url"
        ;;
      *)
        echo "gh-stub: unsupported invocation: pr $pr_sub" >&2
        exit 1
        ;;
    esac
    ;;

  *)
    echo "gh-stub: unsupported invocation: issue $sub" >&2
    exit 1
    ;;
esac
