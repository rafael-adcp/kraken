#!/usr/bin/env python3
"""Programmable `gh` stub for the kraken conformance suite (tests/run-tests.sh
puts this directory first on PATH). It models just enough of GitHub for the
bundled transition program (kraken.py): issue state, labels, and — the part that
matters — server-side comment ordering.

This is the Python port of the original bash stub (issue #38): the internal JSON
assembly moves from `jq` to Python's `json` module, which retires the
CRLF/quoting/locale hazard class that motivated consolidating the transition
scripts into `kraken.py` (#16). The suite's defining property is preserved: the
scripts' own `--jq` expressions are still evaluated by the *real* `jq` (see
`emit`), so the filters under test are the shipped ones, never a reimplementation.
Being on PATH as an executable named `gh`, it is still what a third-party
implementation points its own transition executables at to validate conformance
(PROTOCOL.md §12).

State layout (under $GH_STUB_STATE):
  issues/<n>/title       one line
  issues/<n>/createdAt   ISO timestamp
  issues/<n>/state       "open" | "closed"
  issues/<n>/labels      one label per line
  issues/<n>/body        issue body text (optional; absent = empty body)
  issues/<n>/blocked_by  one blocker issue number per line (optional;
                         absent = no native blockers, i.e. the real API's [])
  issues/<n>/comments/NNNN.md   bodies, NNNN = server order
  issues/<n>/comments/NNNN.at   optional ISO timestamp for that comment
                         (absent = derived from the issue's createdAt); the
                         reaper reads comment createdAt to anchor staleness
  log                    every invocation, one per line

Knobs:
  GH_STUB_FAIL=<ERE>    any invocation whose args match exits 1 (network sim)
  GH_STUB_BARRIER=<n>   `issue view --json labels` blocks until n callers
                        arrive — holds every racer inside the claim window so
                        the race test is deterministic, not timing-dependent

`gh api repos/OWNER/REPO/issues/N/dependencies/blocked_by` models GitHub's
native blocked-by relationships: emits a JSON array of {number, state}, state
read from each blocker's own issues/<n>/state file.

`gh api graphql -f query=...` models the two shapes kraken.py's batched listing
sends (real GraphQL enum state comes back UPPERCASE, unlike the REST endpoints,
so both shapes emit OPEN/CLOSED):
  issues(states: OPEN, labels: [...], first: N[, after: "cursor"])
    -> a page of {number,title,createdAt,body,labels,blockedBy} nodes, real
       cursor pagination (pageInfo.hasNextPage/endCursor).
  aliased `iN: issue(number: N) { state }` fields (the depends-on fallback's
    batched target-state lookup) -> one {data:{repository:{iN:{state}}}} per
    alias, in a single round trip.
"""
import base64
import json
import os
import re
import subprocess
import sys
import time

STATE = os.environ.get("GH_STUB_STATE")
if not STATE:
    sys.stderr.write("gh stub: GH_STUB_STATE not set\n")
    sys.exit(1)

ARGV = sys.argv[1:]
JOINED = " ".join(ARGV)

# Every invocation, one per line — tests assert on call presence/count/order.
with open(os.path.join(STATE, "log"), "a", encoding="utf-8") as _log:
    _log.write("gh %s\n" % JOINED)

_fail = os.environ.get("GH_STUB_FAIL")
if _fail and re.search(_fail, JOINED):
    sys.stderr.write("gh-stub: injected failure for: %s\n" % JOINED)
    sys.exit(1)

LOCKDIR = os.path.join(STATE, ".lock")


def die(msg, code=1):
    sys.stderr.write(msg + "\n")
    sys.exit(code)


# mkdir is the only portable atomic primitive (Git Bash has no flock) — it
# serializes writes, which is exactly GitHub's server-side ordering.
def lock():
    i = 0
    while True:
        try:
            os.mkdir(LOCKDIR)
            return
        except FileExistsError:
            time.sleep(0.05)
            i += 1
            if i > 200:
                die("gh-stub: lock timeout", 99)


def unlock():
    os.rmdir(LOCKDIR)


def read_text(path):
    with open(path, encoding="utf-8") as f:
        return f.read()


def cmdsub(text):
    """Trailing-newline stripping, matching bash `$(cat ...)`."""
    return text.rstrip("\n")


def rtrimnl(text):
    """jq rtrimstr("\\n"): drop a single trailing newline."""
    return text[:-1] if text.endswith("\n") else text


def lines_of(content):
    """The lines `jq -R` would read from `content` (each newline-terminated
    line; a final unterminated line still counts; an empty file yields none)."""
    parts = content.split("\n")
    if parts and parts[-1] == "":
        parts.pop()
    return parts


def label_names(labels_content):
    """issue_json-style label parse: split, drop empty entries."""
    return [x for x in rtrimnl(labels_content).split("\n") if x != ""]


# --- argument parsing (only the shapes kraken.py uses) -----------------------
def parse_args(args):
    p = {
        "sub": "", "issue": "", "jsonf": "", "jqexpr": "", "add_label": "",
        "remove_label": "", "body": "", "endpoint": "", "limit": "", "repo": "",
        "pr_sub": "", "title": "", "head": "", "base": "", "draft": 0,
        "gql_query": "", "label_sub": "", "repo_sub": "", "method": "",
        "put_content": "", "put_message": "", "color": "", "desc": "",
        "label_filters": [],
    }
    i = 0
    n = len(args)
    while i < n:
        a = args[i]
        nxt = args[i + 1] if i + 1 < n else ""
        if a == "-R":
            p["repo"] = nxt; i += 2
        elif a == "issue":
            p["sub"] = nxt; i += 2
        elif a == "repo":
            p["sub"] = "repo"; p["repo_sub"] = nxt; i += 2
        elif a == "pr":
            p["sub"] = "pr"; p["pr_sub"] = nxt; i += 2
        elif a == "label":
            p["sub"] = "label"; p["label_sub"] = nxt; i += 2
        elif a == "api":
            p["sub"] = "api"; p["endpoint"] = nxt; i += 2
        elif a == "--json":
            p["jsonf"] = nxt; i += 2
        elif a == "--jq":
            p["jqexpr"] = nxt; i += 2
        elif a == "--label":
            p["label_filters"].append(nxt); i += 2
        elif a == "--add-label":
            p["add_label"] = nxt; i += 2
        elif a == "--remove-label":
            p["remove_label"] = nxt; i += 2
        elif a == "--title":
            p["title"] = nxt; i += 2
        elif a == "--head":
            p["head"] = nxt; i += 2
        elif a == "--base":
            p["base"] = nxt; i += 2
        elif a in ("--draft", "-d"):
            p["draft"] = 1; i += 1
        elif a in ("-X", "--method"):
            p["method"] = nxt; i += 2
        elif a == "--color":
            p["color"] = nxt; i += 2
        elif a == "--description":
            p["desc"] = nxt; i += 2
        elif a == "--force":
            i += 1
        elif a == "--body":
            p["body"] = nxt; i += 2
        elif a == "--body-file":
            p["body"] = cmdsub(read_text(nxt)); i += 2
        elif a == "--limit":
            p["limit"] = nxt; i += 2
        elif a == "--state":
            i += 2
        elif a in ("-f", "-F"):
            if nxt.startswith("query="):
                p["gql_query"] = nxt[len("query="):]
            elif nxt.startswith("content="):
                p["put_content"] = nxt[len("content="):]
            elif nxt.startswith("message="):
                p["put_message"] = nxt[len("message="):]
            i += 2
        elif a.startswith("-"):
            i += 1
        else:
            p["issue"] = a; i += 1
    return p


P = parse_args(ARGV)


# --- JSON assembly (was jq -n / --rawfile in the bash stub) ------------------
def comments_json(d):
    """[{body, createdAt}] in server order. A comment's createdAt comes from its
    .at sidecar when present, else derived from the issue's createdAt."""
    created = cmdsub(read_text(os.path.join(d, "createdAt")))
    cdir = os.path.join(d, "comments")
    out = []
    for f in sorted(_glob_md(cdir)):
        at_file = f[:-3] + ".at"
        at = cmdsub(read_text(at_file)) if os.path.isfile(at_file) else created
        # jq -Rs slurps the whole file as one string, trailing newline included.
        out.append({"body": read_text(f), "createdAt": at})
    return out


def _glob_md(cdir):
    if not os.path.isdir(cdir):
        return []
    return [os.path.join(cdir, e) for e in os.listdir(cdir) if e.endswith(".md")]


def issue_json(d):
    """{number,title,createdAt,updatedAt,labels:[{name}],comments}."""
    n = int(os.path.basename(d.rstrip("/")))
    title = rtrimnl(read_text(os.path.join(d, "title")))
    created = rtrimnl(read_text(os.path.join(d, "createdAt")))
    comments = comments_json(d)
    labels = [{"name": x} for x in label_names(read_text(os.path.join(d, "labels")))]
    updated = max([c["createdAt"] for c in comments] + [created])
    return {
        "number": n, "title": title, "createdAt": created,
        "updatedAt": updated, "labels": labels, "comments": comments,
    }


def blocked_by_nodes(d, upper):
    """[{number,state}] — state UPPERCASE (graphql) or lowercase (REST)."""
    items = []
    bf = os.path.join(d, "blocked_by")
    if os.path.isfile(bf):
        for bn in lines_of(read_text(bf)):
            if not bn:
                continue
            sf = os.path.join(STATE, "issues", bn, "state")
            default = "CLOSED" if upper else "closed"
            st = cmdsub(read_text(sf)) if os.path.isfile(sf) else default
            if upper:
                st = st.upper()
            items.append({"number": int(bn), "state": st})
    return items


def issue_node_json(d):
    """The GraphQL-shaped issue node."""
    n = int(os.path.basename(d.rstrip("/")))
    title = rtrimnl(read_text(os.path.join(d, "title")))
    created = rtrimnl(read_text(os.path.join(d, "createdAt")))
    labels = [{"name": x} for x in label_names(read_text(os.path.join(d, "labels")))]
    bpath = os.path.join(d, "body")
    body = cmdsub(read_text(bpath)) if os.path.isfile(bpath) else ""
    return {
        "number": n, "title": title, "createdAt": created, "body": body,
        "labels": {"nodes": labels},
        "blockedBy": {"nodes": blocked_by_nodes(d, upper=True)},
    }


def issue_dirs():
    idir = os.path.join(STATE, "issues")
    if not os.path.isdir(idir):
        return []
    out = []
    for e in sorted(os.listdir(idir)):
        d = os.path.join(idir, e)
        if os.path.isdir(d):
            out.append(d)
    return out


def is_open(d):
    return cmdsub(read_text(os.path.join(d, "state"))) == "open"


def has_all_labels(d, labels):
    present = label_names(read_text(os.path.join(d, "labels")))
    return all(l in present for l in labels)


# --- graphql: query-shape dispatch -------------------------------------------
def graphql_list_issues(q):
    m = re.search(r'name: "([^"]*)"', q)
    name = m.group(1) if m else ""
    if not name:
        die("gh-stub: graphql listing query missing repository name")
    lm = re.search(r"labels: \[[^\]]*\]", q)
    labels = re.findall(r'"([^"]*)"', lm.group(0)) if lm else []
    fm = re.search(r"first: ([0-9]+)", q)
    first = int(fm.group(1)) if fm else 100
    am = re.search(r'after: "([^"]*)"', q)
    after = am.group(1) if am else ""

    nodes = []
    for d in issue_dirs():
        if not is_open(d):
            continue
        if not has_all_labels(d, labels):
            continue
        nodes.append(issue_node_json(d))
    nodes.sort(key=lambda x: (x["createdAt"], x["number"]))
    if after != "":
        after_n = int(after)
        nodes = [x for x in nodes if x["number"] > after_n]
    count = len(nodes)
    page = nodes[:first]
    has_next = count > first
    end_cursor = str(page[-1]["number"]) if page else ""
    return {"data": {"repository": {"issues": {
        "pageInfo": {"hasNextPage": has_next, "endCursor": end_cursor},
        "nodes": page,
    }}}}


def graphql_issue_states(q):
    fields = {}
    for m in re.finditer(r"([a-zA-Z_][a-zA-Z0-9_]*): issue\(number: ([0-9]+)\)", q):
        alias, num = m.group(1), m.group(2)
        sf = os.path.join(STATE, "issues", num, "state")
        st = cmdsub(read_text(sf)).upper() if os.path.isfile(sf) else "CLOSED"
        fields[alias] = {"state": st}
    return {"data": {"repository": fields}}


def graphql_dispatch(q):
    if "issues(states: OPEN" in q:
        return graphql_list_issues(q)
    return graphql_issue_states(q)


# --- output ------------------------------------------------------------------
def emit(obj):
    """Print JSON; apply --jq like gh does (raw strings, like jq -r). The
    scripts' own --jq expressions are handed to the REAL jq, so the filters
    under test are the shipped ones. CR is stripped: harmless on LF output,
    but a stray \\r poisons a consumer reading a timestamp/number off a line."""
    data = json.dumps(obj)
    if P["jqexpr"]:
        proc = subprocess.run(
            ["jq", "-r", P["jqexpr"]],
            input=data, capture_output=True, text=True,
        )
        sys.stdout.write(proc.stdout.replace("\r", ""))
        if proc.returncode != 0:
            sys.stderr.write(proc.stderr)
            sys.exit(proc.returncode)
    else:
        sys.stdout.write((data + "\n").replace("\r", ""))


def issue_dir(n):
    d = os.path.join(STATE, "issues", str(n))
    if not os.path.isdir(d):
        die("gh-stub: no such issue %s" % n)
    return d


# --- subcommand dispatch -----------------------------------------------------
def do_list():
    items = [issue_json(d) for d in issue_dirs()
             if is_open(d) and has_all_labels(d, P["label_filters"])]
    # Honor --limit like real gh: page-fetch newest-first (created desc) and
    # stop at the ceiling — an over-limit queue silently loses its OLDEST tasks.
    items.sort(key=lambda x: x["createdAt"])
    items.reverse()
    if P["limit"]:
        items = items[:int(P["limit"])]
    emit(items)


def do_view():
    d = issue_dir(P["issue"])
    jsonf = P["jsonf"]
    labels_src = os.path.join(d, "labels")
    barrier = os.environ.get("GH_STUB_BARRIER")
    if jsonf == "labels" and barrier:
        bdir = os.path.join(STATE, ".barrier")
        os.makedirs(bdir, exist_ok=True)
        open(os.path.join(bdir, str(os.getpid())), "w").close()
        i = 0
        while len(os.listdir(bdir)) < int(barrier):
            time.sleep(0.05)
            i += 1
            if i > 600:  # ~30s ceiling: a cold interpreter must not look stuck.
                break
        # All racers arrived. The first arriver snapshots the labels under the
        # lock; every racer reads that pre-race snapshot, so all guards see the
        # identical clear state the race is meant to test.
        lock()
        snap = os.path.join(bdir, "labels.snap")
        if not os.path.isfile(snap):
            with open(snap, "w", encoding="utf-8") as out:
                out.write(read_text(labels_src))
        unlock()
        labels_src = snap

    if jsonf == "labels":
        names = lines_of(read_text(labels_src))
        emit({"labels": [{"name": x} for x in names]})
    elif jsonf == "body":
        bpath = os.path.join(d, "body")
        body = cmdsub(read_text(bpath)) if os.path.isfile(bpath) else ""
        emit({"body": body})
    elif jsonf == "state":
        st = cmdsub(read_text(os.path.join(d, "state"))).upper()
        emit({"state": st})
    elif jsonf == "comments":
        c = [{"body": read_text(f)} for f in sorted(_glob_md(os.path.join(d, "comments")))]
        emit({"comments": c})
    else:
        die("gh-stub: unsupported --json '%s' for issue view" % jsonf)


def do_edit():
    d = issue_dir(P["issue"])
    lpath = os.path.join(d, "labels")
    lock()
    try:
        labels = lines_of(read_text(lpath))
        if P["add_label"] and P["add_label"] not in labels:
            labels.append(P["add_label"])
        if P["remove_label"]:
            labels = [l for l in labels if l != P["remove_label"]]
        with open(lpath, "w", encoding="utf-8") as f:
            f.write("".join(l + "\n" for l in labels))
    finally:
        unlock()


def do_comment():
    d = issue_dir(P["issue"])
    cdir = os.path.join(d, "comments")
    lock()
    try:
        n = len(_glob_md(cdir)) + 1
        tmp = os.path.join(cdir, ".tmp.%d" % os.getpid())
        with open(tmp, "w", encoding="utf-8") as f:
            f.write(P["body"] + "\n")
        os.replace(tmp, os.path.join(cdir, "%04d.md" % n))
    finally:
        unlock()


def do_api():
    endpoint = P["endpoint"]
    if re.search(r"/issues/[0-9]+/comments", endpoint):
        m = re.search(r"/issues/([0-9]+)/comments", endpoint)
        d = issue_dir(m.group(1))
        emit(comments_json(d))
    elif re.search(r"/issues/[0-9]+/dependencies/blocked_by", endpoint):
        m = re.search(r"/issues/([0-9]+)/dependencies/blocked_by", endpoint)
        d = issue_dir(m.group(1))
        emit(blocked_by_nodes(d, upper=False))
    elif endpoint == "graphql":
        emit(graphql_dispatch(P["gql_query"]))
    elif "/contents/" in endpoint:
        cpath = endpoint.split("/contents/", 1)[1]
        cfile = os.path.join(STATE, "contents", cpath)
        if P["method"] == "PUT":
            lock()
            try:
                os.makedirs(os.path.dirname(cfile), exist_ok=True)
                raw = base64.b64decode(P["put_content"].replace("\n", ""))
                with open(cfile, "wb") as f:
                    f.write(raw)
            finally:
                unlock()
            sys.stdout.write(json.dumps({"content": {"path": cpath}}) + "\n")
        else:
            if not os.path.isfile(cfile):
                die("gh-stub: 404 contents/%s" % cpath)
            with open(cfile, "rb") as f:
                enc = base64.b64encode(f.read()).decode("ascii")
            emit({"content": enc})
    else:
        die("gh-stub: unsupported api endpoint '%s'" % endpoint)


def do_pr():
    if P["pr_sub"] == "create":
        lock()
        try:
            prdir = os.path.join(STATE, "pr")
            os.makedirs(prdir, exist_ok=True)
            n = len(os.listdir(prdir)) + 1
            repo = P["repo"] or "owner/repo"
            url = "https://github.com/%s/pull/%d" % (repo, n)
            obj = {
                "repo": P["repo"], "title": P["title"], "body": P["body"],
                "head": P["head"], "base": P["base"], "draft": P["draft"] == 1,
                "url": url, "state": "OPEN", "mergedAt": None,
            }
            with open(os.path.join(prdir, "%04d.json" % n), "w", encoding="utf-8") as f:
                f.write(json.dumps(obj))
        finally:
            unlock()
        sys.stdout.write(url + "\n")
    elif P["pr_sub"] == "view":
        m = re.search(r"/pull/([0-9]+)", P["issue"])
        prn = m.group(1) if m else ""
        f = os.path.join(STATE, "pr", "%04d.json" % int(prn)) if prn else ""
        if not f or not os.path.isfile(f):
            die("gh-stub: no such pr %s" % P["issue"])
        emit(json.loads(read_text(f)))
    else:
        die("gh-stub: unsupported invocation: pr %s" % P["pr_sub"])


def do_label():
    if P["label_sub"] == "list":
        names = set()
        for d in issue_dirs():
            for l in lines_of(read_text(os.path.join(d, "labels"))):
                if l:
                    names.add(l)
        reg = os.path.join(STATE, "labels")
        if os.path.isfile(reg):
            for l in lines_of(read_text(reg)):
                if l:
                    names.add(l)
        emit([{"name": x} for x in sorted(names)])
    elif P["label_sub"] == "create":
        name = P["issue"]
        lock()
        try:
            meta = os.path.join(STATE, "labels-meta")
            os.makedirs(meta, exist_ok=True)
            reg = os.path.join(STATE, "labels")
            existing = lines_of(read_text(reg)) if os.path.isfile(reg) else []
            if name not in existing:
                with open(reg, "a", encoding="utf-8") as f:
                    f.write(name + "\n")
            with open(os.path.join(meta, name), "w", encoding="utf-8") as f:
                f.write("color=%s\ndescription=%s\n" % (P["color"], P["desc"]))
        finally:
            unlock()
    else:
        die("gh-stub: unsupported invocation: label %s" % P["label_sub"])


def do_repo():
    slug_file = os.path.join(STATE, "repo", "nameWithOwner")
    if P["repo_sub"] == "view":
        if os.path.isfile(slug_file):
            emit({"nameWithOwner": cmdsub(read_text(slug_file))})
        else:
            die("gh-stub: repo not found: %s" % P["issue"])
    elif P["repo_sub"] == "create":
        lock()
        try:
            os.makedirs(os.path.join(STATE, "repo"), exist_ok=True)
            with open(slug_file, "w", encoding="utf-8") as f:
                f.write(P["issue"] + "\n")
        finally:
            unlock()
    else:
        die("gh-stub: unsupported invocation: repo %s" % P["repo_sub"])


DISPATCH = {
    "list": do_list, "view": do_view, "edit": do_edit, "comment": do_comment,
    "api": do_api, "pr": do_pr, "label": do_label, "repo": do_repo,
}

handler = DISPATCH.get(P["sub"])
if handler is None:
    die("gh-stub: unsupported invocation: issue %s" % P["sub"])
handler()
