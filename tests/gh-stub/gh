#!/usr/bin/env bash
# Programmable `gh` stub for the kraken conformance suite (tests/run-tests.sh
# puts this directory first on PATH). It models just enough of GitHub for the
# bundled transition program (kraken.py): issue state, labels, and — the part that matters —
# server-side comment ordering. The scripts' own --jq expressions are evaluated
# by the real `jq`, so the filters under test are the shipped ones, never a
# reimplementation.
#
# State layout (under $GH_STUB_STATE):
#   issues/<n>/title       one line
#   issues/<n>/createdAt   ISO timestamp
#   issues/<n>/state       "open" | "closed"
#   issues/<n>/labels      one label per line
#   issues/<n>/body        issue body text (optional; absent = empty body)
#   issues/<n>/blocked_by  one blocker issue number per line (optional;
#                          absent = no native blockers, i.e. the real API's [])
#   issues/<n>/comments/NNNN.md   bodies, NNNN = server order
#   issues/<n>/comments/NNNN.at   optional ISO timestamp for that comment
#                          (absent = derived from the issue's createdAt); the
#                          reaper reads comment createdAt to anchor staleness
#   log                    every invocation, one per line
#
# Knobs:
#   GH_STUB_FAIL=<ERE>    any invocation whose args match exits 1 (network sim)
#   GH_STUB_BARRIER=<n>   `issue view --json labels` blocks until n callers
#                         arrive — holds every racer inside the claim window so
#                         the race test is deterministic, not timing-dependent
#
# `gh api repos/OWNER/REPO/issues/N/dependencies/blocked_by` models GitHub's
# native blocked-by relationships: emits a JSON array of {number, state},
# state read from each blocker's own issues/<n>/state file, so closing a
# blocker in the stub is exactly `echo closed > issues/<n>/state`.
#
# `gh api graphql -f query=...` models the two shapes kraken.py's batched
# listing sends (real GraphQL enum state comes back UPPERCASE, unlike the
# REST endpoints above, so both shapes below emit OPEN/CLOSED):
#   issues(states: OPEN, labels: [...], first: N[, after: "cursor"])
#     -> a page of {number,title,createdAt,body,labels,blockedBy} nodes, real
#        cursor pagination (pageInfo.hasNextPage/endCursor) so an over-100
#        queue still takes the number of calls its page count needs.
#   aliased `iN: issue(number: N) { state }` fields (the depends-on fallback's
#     batched target-state lookup) -> one {data:{repository:{iN:{state}}}} per
#     alias, in a single round trip regardless of how many aliases are asked.
set -u

STATE="${GH_STUB_STATE:?gh stub: GH_STUB_STATE not set}"
printf 'gh %s\n' "$*" >> "$STATE/log"

if [ -n "${GH_STUB_FAIL:-}" ] && printf '%s' "$*" | grep -Eq "$GH_STUB_FAIL"; then
  echo "gh-stub: injected failure for: $*" >&2
  exit 1
fi

# mkdir is the only portable atomic primitive (Git Bash has no flock) — it
# serializes writes, which is exactly GitHub's server-side ordering.
lock() {
  local i=0
  until mkdir "$STATE/.lock" 2>/dev/null; do
    sleep 0.05
    i=$((i + 1))
    [ "$i" -gt 200 ] && { echo "gh-stub: lock timeout" >&2; exit 99; }
  done
}
unlock() { rmdir "$STATE/.lock"; }

# --- argument parsing (only the shapes kraken.py uses) -----------
# `pr` is here only for the agent-behavior harness (tests/agent): the unleash
# skill opens the delivery PR with `gh pr create`, which kraken.py never
# calls, so the conformance suite never reaches this branch. We record the PR
# as an artifact (pr/NNNN.json) instead of talking to GitHub, and capture -R's
# repo (the conformance paths ignore it) so a PR is attributable to a repo.
sub="" issue="" jsonf="" jqexpr="" add_label="" remove_label="" body="" endpoint="" limit=""
repo="" pr_sub="" title="" head="" base="" draft=0 gql_query="" label_sub=""
repo_sub="" method="" put_content="" put_message="" color="" desc=""
label_filters=()
while [ $# -gt 0 ]; do
  case "$1" in
    -R)             repo="$2"; shift 2 ;;
    issue)          sub="$2"; shift 2 ;;
    repo)           sub="repo"; repo_sub="$2"; shift 2 ;;
    pr)             sub="pr"; pr_sub="$2"; shift 2 ;;
    label)          sub="label"; label_sub="$2"; shift 2 ;;
    api)            sub="api"; endpoint="$2"; shift 2 ;;
    --json)         jsonf="$2"; shift 2 ;;
    --jq)           jqexpr="$2"; shift 2 ;;
    --label)        label_filters+=("$2"); shift 2 ;;
    --add-label)    add_label="$2"; shift 2 ;;
    --remove-label) remove_label="$2"; shift 2 ;;
    --title)        title="$2"; shift 2 ;;
    --head)         head="$2"; shift 2 ;;
    --base)         base="$2"; shift 2 ;;
    --draft | -d)   draft=1; shift ;;
    -X | --method)  method="$2"; shift 2 ;;
    --color)        color="$2"; shift 2 ;;
    --description)  desc="$2"; shift 2 ;;
    --force)        shift ;;
    --body)         body="$2"; shift 2 ;;
    --body-file)    body="$(cat "$2")"; shift 2 ;;
    --limit)        limit="$2"; shift 2 ;;
    --state)        shift 2 ;;
    -f | -F)        case "$2" in
                      query=*)   gql_query="${2#query=}" ;;
                      content=*) put_content="${2#content=}" ;;
                      message=*) put_message="${2#message=}" ;;
                    esac; shift 2 ;;
    -*)             shift ;;
    *)              issue="$1"; shift ;;
  esac
done

comments_json() { # $1 = issue dir; emit [{body, createdAt}] in server order.
  # A comment's createdAt comes from its .at sidecar when present, else it is
  # derived from the issue's createdAt so ordering stays stable — the reaper
  # anchors staleness to the newest worker machine line's createdAt.
  local d="$1" f at bodies="" created
  created="$(cat "$d/createdAt")"
  for f in "$d"/comments/*.md; do
    [ -f "$f" ] || continue
    if [ -f "${f%.md}.at" ]; then
      at="$(cat "${f%.md}.at")"
    else
      at="$created"
    fi
    bodies="${bodies}$(jq -Rs --arg at "$at" '{body: ., createdAt: $at}' < "$f")"
  done
  printf '%s' "$bodies" | jq -s .
}

issue_json() { # $1 = issue dir; emit {number,title,createdAt,updatedAt,labels:[{name}],comments}
  # One jq per issue (not four): the list case builds a whole queue, so a
  # tighter fork budget here is what keeps large-queue cases (tests/t/14)
  # from dominating the suite. Files are read straight into jq via --rawfile.
  # updatedAt is the newest comment createdAt (or the issue createdAt when no
  # comment exists), so a list caller reading .updatedAt sees a plausible value.
  local d="$1" comments
  comments="$(comments_json "$d")"
  jq -n \
    --arg n "$(basename "$d")" \
    --rawfile title "$d/title" \
    --rawfile created "$d/createdAt" \
    --argjson comments "$comments" \
    --rawfile labels "$d/labels" \
    '{
       number: ($n | tonumber),
       title: ($title | rtrimstr("\n")),
       createdAt: ($created | rtrimstr("\n")),
       updatedAt: ([$comments[].createdAt] + [($created | rtrimstr("\n"))] | max),
       labels: ($labels | rtrimstr("\n") | split("\n") | map(select(. != "") | {name: .})),
       comments: $comments
     }'
}

# --- graphql: query-shape dispatch ------------------------------------------
# kraken.py never uses gh's -F (typed) vs -f (string) distinction meaningfully
# here — every value it needs (owner, repo, project, labels, cursor) is
# embedded straight into the query text, one clause per line, so a per-line
# grep -oE finds each token without a real GraphQL parser.

blocked_by_nodes_json() { # $1 = issue dir; emit [{number,state}] UPPERCASE
  local d="$1" items="" bn bstate
  if [ -f "$d/blocked_by" ]; then
    while IFS= read -r bn; do
      [ -n "$bn" ] || continue
      bstate="CLOSED"
      [ -f "$STATE/issues/$bn/state" ] && bstate="$(cat "$STATE/issues/$bn/state" | tr '[:lower:]' '[:upper:]')"
      items="${items}$(jq -n --argjson num "$bn" --arg state "$bstate" '{number:$num, state:$state}')"
    done < "$d/blocked_by"
  fi
  printf '%s' "$items" | jq -s .
}

issue_node_json() { # $1 = issue dir; emit the GraphQL-shaped issue node
  local d="$1"
  jq -n \
    --arg n "$(basename "$d")" \
    --rawfile title "$d/title" \
    --rawfile created "$d/createdAt" \
    --rawfile labels "$d/labels" \
    --arg body "$([ -f "$d/body" ] && cat "$d/body" || true)" \
    --argjson blockedby "$(blocked_by_nodes_json "$d")" \
    '{
       number: ($n | tonumber),
       title: ($title | rtrimstr("\n")),
       createdAt: ($created | rtrimstr("\n")),
       body: $body,
       labels: {nodes: ($labels | rtrimstr("\n") | split("\n") | map(select(. != "") | {name: .}))},
       blockedBy: {nodes: $blockedby}
     }'
}

graphql_list_issues() { # $1 = query text; a paginated kraken-task listing page
  local q="$1" name label_line labels=() first after items="" all count page has_next end_cursor
  name="$(printf '%s\n' "$q" | grep -oE 'name: "[^"]*"' | head -1 | sed -E 's/^name: "//; s/"$//')"
  label_line="$(printf '%s\n' "$q" | grep -oE 'labels: \[[^]]*\]' | head -1)"
  while IFS= read -r l; do labels+=("$l"); done < <(printf '%s' "$label_line" | grep -oE '"[^"]*"' | tr -d '"')
  first="$(printf '%s\n' "$q" | grep -oE 'first: [0-9]+' | head -1 | grep -oE '[0-9]+')"
  after="$(printf '%s\n' "$q" | grep -oE 'after: "[^"]*"' | head -1 | sed -E 's/^after: "//; s/"$//')"
  : "${name:?gh-stub: graphql listing query missing repository name}"

  for d in "$STATE"/issues/*/; do
    [ -d "$d" ] || continue
    [ "$(cat "$d/state")" = "open" ] || continue
    ok=1
    for lf in ${labels[@]+"${labels[@]}"}; do
      grep -qxF -- "$lf" "$d/labels" || { ok=0; break; }
    done
    [ "$ok" -eq 1 ] || continue
    items="${items}$(issue_node_json "$d")"
  done
  all="$(printf '%s' "$items" | jq -s 'sort_by(.createdAt, .number)')"
  if [ -n "$after" ]; then
    all="$(printf '%s' "$all" | jq --argjson after "$after" '[.[] | select(.number > $after)]')"
  fi
  count="$(printf '%s' "$all" | jq 'length')"
  page="$(printf '%s' "$all" | jq --argjson n "${first:-100}" '.[:$n]')"
  has_next="false"
  [ "$count" -gt "${first:-100}" ] && has_next="true"
  end_cursor=""
  [ "$(printf '%s' "$page" | jq 'length')" -gt 0 ] && end_cursor="$(printf '%s' "$page" | jq -r '.[-1].number')"
  jq -n --argjson nodes "$page" --argjson hasNext "$has_next" --arg endCursor "$end_cursor" \
    '{data:{repository:{issues:{pageInfo:{hasNextPage:$hasNext, endCursor:$endCursor}, nodes:$nodes}}}}'
}

graphql_issue_states() { # $1 = query text; batched `iN: issue(number: N) { state }` aliases
  local q="$1" m alias num st fields=""
  while IFS= read -r m; do
    [ -n "$m" ] || continue
    alias="$(printf '%s' "$m" | sed -E 's/^([a-zA-Z_][a-zA-Z0-9_]*): issue.*/\1/')"
    num="$(printf '%s' "$m" | sed -E 's/.*issue\(number: ([0-9]+)\).*/\1/')"
    st="CLOSED"
    [ -f "$STATE/issues/$num/state" ] && st="$(cat "$STATE/issues/$num/state" | tr '[:lower:]' '[:upper:]')"
    fields="${fields}$(jq -n --arg k "$alias" --arg st "$st" '{($k): {state:$st}}')"
  done < <(printf '%s\n' "$q" | grep -oE '[a-zA-Z_][a-zA-Z0-9_]*: issue\(number: [0-9]+\)')
  jq -n --argjson repo "$(printf '%s' "$fields" | jq -s 'add // {}')" '{data:{repository:$repo}}'
}

graphql_dispatch() { # $1 = query text
  if printf '%s\n' "$1" | grep -q 'issues(states: OPEN'; then
    graphql_list_issues "$1"
  else
    graphql_issue_states "$1"
  fi
}

emit() { # $1 = JSON; apply --jq like gh does (raw strings, like jq -r)
  # Strip CR: real gh (and Linux CI's jq) emit LF, but jq's Windows build writes
  # CRLF, and a trailing \r poisons a consumer that reads a timestamp/number off
  # a line (the reaper's `date -d "$anchor"`). Harmless on LF-only output.
  { if [ -n "$jqexpr" ]; then
    printf '%s' "$1" | jq -r "$jqexpr"
  else
    printf '%s\n' "$1"
  fi ; } | tr -d '\r'
}

case "$sub" in
  list)
    items=""
    for d in "$STATE"/issues/*/; do
      [ -d "$d" ] || continue
      [ "$(cat "$d/state")" = "open" ] || continue
      ok=1
      for lf in ${label_filters[@]+"${label_filters[@]}"}; do
        grep -qxF -- "$lf" "$d/labels" || { ok=0; break; }
      done
      [ "$ok" -eq 1 ] || continue
      items="${items}$(issue_json "$d")"
    done
    # Honor --limit like real gh: it page-fetches newest-first (created desc)
    # and stops at the ceiling, so an over-limit queue silently loses its
    # OLDEST tasks. Modeling that truncation is what gives the pagination
    # conformance case (tests/t/14) its teeth; absent --limit means no cap.
    all="$(printf '%s' "$items" | jq -s 'sort_by(.createdAt) | reverse')"
    if [ -n "$limit" ]; then
      all="$(printf '%s' "$all" | jq --argjson lim "$limit" '.[:$lim]')"
    fi
    emit "$all"
    ;;

  view)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    labels_src="$d/labels"
    if [ "$jsonf" = "labels" ] && [ -n "${GH_STUB_BARRIER:-}" ]; then
      mkdir -p "$STATE/.barrier"
      : > "$STATE/.barrier/$$"
      i=0
      while [ "$(ls "$STATE/.barrier" | wc -l)" -lt "$GH_STUB_BARRIER" ]; do
        sleep 0.05
        i=$((i + 1))
        # A stuck partner must not hang the suite. The ceiling is generous (~30s)
        # so a cold-started worker — kraken.py's interpreter warm-up is slower
        # than a bash script's, especially on a network/overlay filesystem — is
        # never mistaken for a stuck one, which would break the race's pairing.
        [ "$i" -gt 600 ] && break
      done
      # All racers have arrived. The barrier only guaranteed simultaneous
      # ARRIVAL, not a simultaneous read: whoever's guard-gh returns first lets
      # its worker add `in-progress` before a slower racer's read runs, and that
      # racer would then wrongly see a held task and skip (exit 11) instead of
      # racing the claim. So the first arriver snapshots the labels under the
      # lock, and every racer reads that pre-race snapshot — so all guards see
      # the identical clear state the race is meant to test, no matter how the
      # worker interpreters are scheduled.
      lock
      [ -f "$STATE/.barrier/labels.snap" ] || cp "$d/labels" "$STATE/.barrier/labels.snap"
      unlock
      labels_src="$STATE/.barrier/labels.snap"
    fi
    case "$jsonf" in
      labels)
        emit "$(jq -n --argjson labels "$(jq -R '{name: .}' < "$labels_src" | jq -s .)" '{labels: $labels}')"
        ;;
      body)
        emit "$(jq -n --arg body "$([ -f "$d/body" ] && cat "$d/body" || true)" '{body: $body}')"
        ;;
      state)
        st="$(cat "$d/state" | tr '[:lower:]' '[:upper:]')"
        emit "$(jq -n --arg state "$st" '{state: $state}')"
        ;;
      comments)
        bodies=""
        for f in "$d"/comments/*.md; do
          [ -f "$f" ] || continue
          bodies="${bodies}$(jq -Rs '{body: .}' < "$f")"
        done
        emit "$(jq -n --argjson c "$(printf '%s' "$bodies" | jq -s .)" '{comments: $c}')"
        ;;
      *)
        echo "gh-stub: unsupported --json '$jsonf' for issue view" >&2; exit 1
        ;;
    esac
    ;;

  edit)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    lock
    if [ -n "$add_label" ]; then
      grep -qxF -- "$add_label" "$d/labels" || printf '%s\n' "$add_label" >> "$d/labels"
    fi
    if [ -n "$remove_label" ]; then
      grep -vxF -- "$remove_label" "$d/labels" > "$d/labels.tmp" || true
      mv "$d/labels.tmp" "$d/labels"
    fi
    unlock
    ;;

  comment)
    d="$STATE/issues/$issue"
    [ -d "$d" ] || { echo "gh-stub: no such issue $issue" >&2; exit 1; }
    lock
    n=$(( $(ls "$d/comments"/*.md 2>/dev/null | wc -l) + 1 ))
    printf '%s\n' "$body" > "$d/comments/.tmp.$$"
    mv "$d/comments/.tmp.$$" "$d/comments/$(printf '%04d' "$n").md"
    unlock
    ;;

  api)
    # The shapes the transitions need:
    #   repos/OWNER/REPO/issues/N/dependencies/blocked_by -> [{number,state}]
    #   repos/OWNER/REPO/issues/N/comments               -> [{body}]  (paginated
    #     claim-window arbitration; --paginate is a no-op here — the whole thread
    #     is returned in one array, in server order, which is all kraken.py's
    #     line scan needs).
    case "$endpoint" in
      */issues/*/comments)
        n="$(printf '%s' "$endpoint" | sed -n 's#.*/issues/\([0-9][0-9]*\)/comments#\1#p')"
        d="$STATE/issues/$n"
        [ -d "$d" ] || { echo "gh-stub: no such issue $n" >&2; exit 1; }
        # [{body, createdAt}] in server order — comment_bodies' `--jq .[].body`
        # still selects the bodies, while status' comment_records reads the
        # createdAt the heartbeat-age anchor needs (from each .at sidecar, else
        # the issue createdAt), so both paths share this one endpoint.
        emit "$(comments_json "$d")"
        ;;
      */issues/*/dependencies/blocked_by)
        n="$(printf '%s' "$endpoint" | sed -n 's#.*/issues/\([0-9][0-9]*\)/dependencies/blocked_by#\1#p')"
        d="$STATE/issues/$n"
        [ -d "$d" ] || { echo "gh-stub: no such issue $n" >&2; exit 1; }
        items=""
        if [ -f "$d/blocked_by" ]; then
          while IFS= read -r bn; do
            [ -n "$bn" ] || continue
            bstate="closed"
            [ -f "$STATE/issues/$bn/state" ] && bstate="$(cat "$STATE/issues/$bn/state")"
            items="${items}$(jq -n --argjson num "$bn" --arg state "$bstate" '{number: $num, state: $state}')"
          done < "$d/blocked_by"
        fi
        emit "$(printf '%s' "$items" | jq -s .)"
        ;;
      graphql)
        emit "$(graphql_dispatch "$gql_query")"
        ;;
      */contents/*)
        # The init contents API: GET returns {content:<base64>} of the stored
        # file (used by kraken.py's `--jq .content`), a 404 (exit 1) when absent;
        # PUT (-X PUT -f content=<base64>) creates the file. Files live under
        # $STATE/contents/<path>, not namespaced by repo (the conformance paths
        # use a single repo). This is what lets init be tested for create /
        # skip-unchanged / flag-customized without a real GitHub.
        cpath="${endpoint#*/contents/}"
        cfile="$STATE/contents/$cpath"
        if [ "$method" = "PUT" ]; then
          lock
          mkdir -p "$(dirname "$cfile")"
          printf '%s' "$put_content" | tr -d '\n' | base64 -d > "$cfile"
          unlock
          jq -n --arg p "$cpath" '{content:{path:$p}}'
        else
          [ -f "$cfile" ] || { echo "gh-stub: 404 contents/$cpath" >&2; exit 1; }
          emit "$(jq -n --arg c "$(base64 < "$cfile" | tr -d '\n')" '{content:$c}')"
        fi
        ;;
      *)
        echo "gh-stub: unsupported api endpoint '$endpoint'" >&2; exit 1
        ;;
    esac
    ;;

  pr)
    # Only `pr create` — the delivery PR the unleash skill opens on the work
    # repo. Record it as an artifact (never a real GitHub call) and print a
    # plausible URL on stdout, exactly what real `gh pr create` emits, so the
    # skill can quote it back in the result comment / pr: machine line.
    case "$pr_sub" in
      create)
        lock
        mkdir -p "$STATE/pr"
        n=$(( $(ls "$STATE/pr" 2>/dev/null | wc -l) + 1 ))
        url="https://github.com/${repo:-owner/repo}/pull/${n}"
        jq -n \
          --arg repo "$repo" --arg title "$title" --arg body "$body" \
          --arg head "$head" --arg base "$base" \
          --argjson draft "$draft" --arg url "$url" \
          '{repo:$repo, title:$title, body:$body, head:$head, base:$base, draft:($draft==1), url:$url, state:"OPEN", mergedAt:null}' \
          > "$STATE/pr/$(printf '%04d' "$n").json"
        unlock
        printf '%s\n' "$url"
        ;;
      view)
        # `gh pr view <url> --json state,mergedAt` — the orphan heuristic's only
        # PR read. The URL's /pull/<n> maps to pr/<n>.json (seeded by mk_pr, or
        # written by `pr create` above). Emit the stored object; --json field
        # selection is honored by kraken.py reading .state/.mergedAt off it.
        prn="$(printf '%s' "$issue" | sed -n 's#.*/pull/\([0-9][0-9]*\).*#\1#p')"
        f="$STATE/pr/$(printf '%04d' "$prn").json"
        [ -f "$f" ] || { echo "gh-stub: no such pr $issue" >&2; exit 1; }
        emit "$(cat "$f")"
        ;;
      *)
        echo "gh-stub: unsupported invocation: pr $pr_sub" >&2
        exit 1
        ;;
    esac
    ;;

  label)
    # Only `label list --json name`: the launch recon's project enumeration.
    # Registry = every label the launch recon may point at, whether or not it
    # is currently on an open issue: the union of $STATE/labels (empty projects
    # seeded by mk_label) and every label applied to any issue.
    case "$label_sub" in
      list)
        { for d in "$STATE"/issues/*/; do [ -d "$d" ] && cat "$d/labels"; done
          [ -f "$STATE/labels" ] && cat "$STATE/labels"; } \
          | sed '/^$/d' | sort -u | jq -R '{name: .}' | jq -s . > "$STATE/.labels.$$"
        emit "$(cat "$STATE/.labels.$$")"
        rm -f "$STATE/.labels.$$"
        ;;
      create)
        # `label create NAME --force --color C --description D`: init's canonical
        # label upsert. --force makes it idempotent, so this always succeeds and
        # re-canonicalizes. Register the name (dedup) and record color/description
        # under labels-meta/<name> so a test can assert the canonical values.
        lock
        mkdir -p "$STATE/labels-meta"
        { [ -f "$STATE/labels" ] && grep -qxF -- "$issue" "$STATE/labels"; } \
          || printf '%s\n' "$issue" >> "$STATE/labels"
        printf 'color=%s\ndescription=%s\n' "$color" "$desc" \
          > "$STATE/labels-meta/$issue"
        unlock
        ;;
      *)
        echo "gh-stub: unsupported invocation: label $label_sub" >&2
        exit 1
        ;;
    esac
    ;;

  repo)
    # init's verify-or-create step. `repo view SLUG --json nameWithOwner` succeeds
    # (prints the slug) iff the repo was seeded (mk_repo) or already created here;
    # a missing repo exits 1 so kraken.py's gh_repo_exists reads False. `repo
    # create SLUG --private` records the repo so a re-run's view then finds it.
    case "$repo_sub" in
      view)
        if [ -f "$STATE/repo/nameWithOwner" ]; then
          emit "$(jq -n --arg n "$(cat "$STATE/repo/nameWithOwner")" '{nameWithOwner:$n}')"
        else
          echo "gh-stub: repo not found: $issue" >&2; exit 1
        fi
        ;;
      create)
        lock
        mkdir -p "$STATE/repo"
        printf '%s\n' "$issue" > "$STATE/repo/nameWithOwner"
        unlock
        ;;
      *)
        echo "gh-stub: unsupported invocation: repo $repo_sub" >&2
        exit 1
        ;;
    esac
    ;;

  *)
    echo "gh-stub: unsupported invocation: issue $sub" >&2
    exit 1
    ;;
esac
